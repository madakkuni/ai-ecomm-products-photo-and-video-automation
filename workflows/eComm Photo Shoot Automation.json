    {
      "parameters": {
        "jsCode": "const text = $input.first()?.json?.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\n\nif (!text) {\n  return [{ prompts: [] }];\n}\n\n// Normalize\nconst clean = text.replace(/\\r/g, '');\n\n// Strategy 1: Strong pattern\nlet prompts = [...clean.matchAll(/\\*\\*Prompt\\s*\\d+:[^\\n]*\\*\\*\\s*([\\s\\S]*?)(?=\\n\\s*\\*\\*Prompt\\s*\\d+:|\\n---|$)/gi)]\n  .map(m => m[1].trim());\n\n// Strategy 2: Fallback\nif (prompts.length === 0) {\n  prompts = clean.split(/Prompt\\s*\\d+:/i)\n    .map(p => p.trim())\n    .filter(p => p.length > 50);\n}\n\n// Strategy 3: Hard fallback\nif (prompts.length === 0) {\n  prompts = clean.split(/\\n\\n+/)\n    .map(p => p.trim())\n    .filter(p => p.length > 80);\n}\n\n// Final cleanup\nprompts = prompts.map(p =>\n  p.replace(/\\n+/g, ' ').trim()\n);\n\n// Optional: limit to 8 prompts\nprompts = prompts.slice(0, 8);\n\nreturn [{ prompts }];"
      },
